# Git LFS for large model files
models/*.pkl filter=lfs diff=lfs merge=lfs -text
*.pkl filter=lfs diff=lfs merge=lfs -text

# Python files
*.py text eol=lf
*.pyx text eol=lf
*.pxd text eol=lf

# Data files
*.csv binary
*.parquet binary
*.feather binary

# Model files
*.h5 binary
*.hdf5 binary
*.joblib binary

# Jupyter notebooks
*.ipynb text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
requirements*.txt text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Docker
Dockerfile text eol=lf
docker-compose*.yml text eol=lf
