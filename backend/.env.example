# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=8080

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Model Configuration
